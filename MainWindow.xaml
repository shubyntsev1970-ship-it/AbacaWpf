<Window x:Class="AbacaWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abaca"
        Width="1800"
        Height="950"
        MinWidth="1800"
        MinHeight="950"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#101820"
        Focusable="True"
        PreviewKeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="CommandButton" TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="#214E72"/>
            <Setter Property="BorderBrush" Value="#66E1D6B5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ScoreText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#0B1117" Foreground="#F8FAFC" FontSize="28">
            <MenuItem Header="_Game" Background="#0B1117" Foreground="#F8FAFC">
                <MenuItem Header="_New game" Click="NewGame_Click" Foreground="#111827"/>
                <Separator/>
                <MenuItem Header="_Exit" Click="Exit_Click" Foreground="#111827"/>
            </MenuItem>
            <MenuItem Header="_Help" Background="#0B1117" Foreground="#F8FAFC">
                <MenuItem Header="_Rules" Click="Rules_Click" Foreground="#111827"/>
                <MenuItem Header="_About" Click="About_Click" Foreground="#111827"/>
            </MenuItem>
        </Menu>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="10" CornerRadius="8" Background="#17212B" BorderBrush="#31506D" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="430"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="PlayerOneNameText" Text="Игрок 1" Foreground="#E8F0F7" FontSize="36" FontWeight="Bold"/>
                        <UniformGrid Columns="2" Width="360" HorizontalAlignment="Left" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="Счёт" Foreground="#8FB3C9" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="PlayerOneScoreText" Style="{StaticResource ScoreText}" Text="0"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Школа" Foreground="#8FB3C9" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="PlayerOneSchoolText" Style="{StaticResource ScoreText}" Text="0"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Width="430" HorizontalAlignment="Center" Margin="0">
                        <TextBlock Text="ABACA" Foreground="#F6D365" FontSize="30" FontWeight="Black" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TurnText" Text="Ход игрока" Foreground="#E8F0F7" FontSize="25" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="RollCountText" Text="Бросок: 0 / 3" Foreground="#8FB3C9" FontSize="23" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="PlayerTwoNameText" Text="Игрок 2" Foreground="#E8F0F7" FontSize="36" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <UniformGrid Columns="2" Width="360" HorizontalAlignment="Right" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="Счёт" Foreground="#8FB3C9" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="PlayerTwoScoreText" Style="{StaticResource ScoreText}" Text="0"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Школа" Foreground="#8FB3C9" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="PlayerTwoSchoolText" Style="{StaticResource ScoreText}" Text="0"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="PlayerOnePanel" Grid.Column="0" Margin="24,0" CornerRadius="8" Background="#EAF2F8" BorderBrush="#F6D365" BorderThickness="1" Padding="10">
                    <Grid x:Name="PlayerOneTable"/>
                </Border>
                <Border x:Name="PlayerTwoPanel" Grid.Column="2" Margin="24,0" CornerRadius="8" Background="#EAF2F8" BorderBrush="#3E617C" BorderThickness="1" Padding="10">
                    <Grid x:Name="PlayerTwoTable"/>
                </Border>
            </Grid>

            <Border Grid.Row="2" Padding="10" CornerRadius="8" Background="#17212B" BorderBrush="#31506D" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="178"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ItemsControl x:Name="DiceItems" Grid.Column="1" HorizontalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <StackPanel Grid.Column="2" Margin="18,0,0,0" Width="160">
                        <Button x:Name="RollButton" Content="СТАРТ" Height="44" FontSize="17" FontWeight="Bold" Click="RollButton_Click"/>
                        <TextBlock Text="Клик по кубику фиксирует его. Space - старт/стоп." Foreground="#BBD0DD" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="3" Margin="0,8,0,0" Padding="6" CornerRadius="8" Background="#0F1720" BorderBrush="#31506D" BorderThickness="1">
                <ItemsControl x:Name="CombinationButtons">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="15"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>
